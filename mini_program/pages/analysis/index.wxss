/* pages/analysis/index.wxss */

/* 未连接设备警告 */
.conn-warning {
  background: rgba(250,81,81,0.1);
  border: 1px solid rgba(250,81,81,0.3);
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  text-align: center;
}
.conn-warning-text {
  color: #fa5151;
  font-size: 24rpx;
}

.container {
  min-height: 100vh;
  background: #0d0d0d;
  color: #fff;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* ========== Algo Banner ========== */
.algo-banner {
  margin: 0 16px 0;
  padding: 10px 14px;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.algo-default {
  background: rgba(96,165,250,0.08);
  border: 1px solid rgba(96,165,250,0.2);
}
.algo-personal {
  background: rgba(7,193,96,0.08);
  border: 1px solid rgba(7,193,96,0.2);
}
.algo-label {
  font-size: 13px;
  font-weight: 600;
  color: #fff;
}
.algo-hint {
  font-size: 11px;
  color: #888;
}

/* ========== Filter Bar ========== */
.filter-bar {
  background: #1a1a1a;
  border-bottom: 1px solid #2a2a2a;
  padding: 10px 0;
  margin-top: 8px;
}
.filter-scroll { white-space: nowrap; }
.filter-chips { display: inline-flex; gap: 8px; padding: 0 16px; }
.filter-chip {
  display: inline-block;
  padding: 6px 14px;
  border-radius: 16px;
  font-size: 13px;
  background: #2a2a2a;
  color: #aaa;
  border: 1px solid #3a3a3a;
  flex-shrink: 0;
}
.filter-chip.active {
  background: rgba(7,193,96,0.15);
  color: #07c160;
  border-color: #07c160;
}

/* ========== Date Range Bar ========== */
.date-range-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
  background: #151515;
  border-bottom: 1px solid #2a2a2a;
}
.date-range-text { font-size: 13px; color: #aaa; font-family: monospace; flex: 1; }
.refresh-btn {
  padding: 4px 10px;
  background: #252525;
  border-radius: 6px;
  font-size: 12px;
  color: #aaa;
}

.btn-group {
  display: flex;
  gap: 8px;
}

.query-btn {
  padding: 4px 10px;
  background: #07c160;
  border-radius: 6px;
  font-size: 12px;
  color: #fff;
}

/* ========== Loading / Empty ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 20px;
  gap: 16px;
}
.spinner {
  width: 36px; height: 36px;
  border: 3px solid #333;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 14px; color: #888; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 20px;
  gap: 8px;
}
.empty-title { font-size: 16px; font-weight: 600; color: #fff; }
.empty-desc { font-size: 13px; color: #666; }

/* ========== Summary Cards ========== */
.summary-row {
  display: flex;
  overflow-x: auto;
  padding: 12px 12px 4px;
  gap: 6px;
  scrollbar-width: none;
}
.summary-row::-webkit-scrollbar { display: none; }
.summary-card {
  flex: 0 0 auto;
  min-width: 72px;
  background: #1a1a1a;
  border: 1px solid #2a2a2a;
  border-radius: 8px;
  padding: 10px 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.summary-value {
  font-size: 16px;
  font-weight: bold;
  font-family: monospace;
  color: #07c160;
}
.summary-value.danger { color: #f87171; }
.summary-label { font-size: 10px; color: #666; text-align: center; }

/* ========== Chart Section ========== */
.chart-section {
  margin: 10px 16px;
  background: #1a1a1a;
  border: 1px solid #2a2a2a;
  border-radius: 10px;
  padding: 12px;
}
.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}
.chart-title { font-size: 14px; font-weight: 600; color: #fff; }
.chart-legend {
  display: flex;
  gap: 10px;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 4px;
}
.legend-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
}
.legend-dot.personal { background: #07c160; }
.legend-dot.reference { background: #60a5fa; }
.legend-dot.actual { background: #f87171; }
.legend-text { font-size: 10px; color: #888; }
.mdf-canvas { width: 100%; height: 200px; }
.chart-axes {
  display: flex;
  justify-content: space-between;
  margin-top: 4px;
}
.axis-label-y { font-size: 10px; color: #666; }
.axis-label-x { font-size: 10px; color: #666; }

/* ========== Fatigue Bar ========== */
.fatigue-section {
  margin: 0 16px 8px;
  background: #1a1a1a;
  border: 1px solid #2a2a2a;
  border-radius: 8px;
  padding: 12px;
}
.section-title {
  font-size: 13px;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 10px;
}
.fatigue-bar-bg {
  height: 12px;
  background: #252525;
  border-radius: 6px;
  overflow: hidden;
}
.fatigue-bar-fill {
  height: 100%;
  border-radius: 6px;
  transition: width 0.5s ease;
  background: linear-gradient(90deg, #07c160, #f59e0b, #f87171);
}
.fatigue-ticks {
  display: flex;
  justify-content: space-between;
  margin-top: 4px;
}
.fatigue-tick { font-size: 9px; color: #555; font-family: monospace; }

/* ========== Detail Table ========== */
.detail-section {
  margin: 0 16px 8px;
  background: #1a1a1a;
  border: 1px solid #2a2a2a;
  border-radius: 8px;
  padding: 12px;
}
.detail-table {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.detail-row {
  display: flex;
  padding: 8px 0;
  border-bottom: 1px solid #222;
}
.detail-row:last-child { border-bottom: none; }
.detail-header .detail-cell { color: #888; font-weight: 600; font-size: 11px; }
.detail-cell {
  flex: 1;
  font-size: 12px;
  color: #ccc;
  font-family: monospace;
  text-align: center;
}
.detail-cell.danger { color: #f87171; }
.detail-more {
  font-size: 11px;
  color: #555;
  text-align: center;
  display: block;
  margin-top: 8px;
}

/* ========== Action Bar ========== */
.action-bar {
  display: flex;
  gap: 10px;
  padding: 10px 16px 16px;
}
.action-bar .btn { flex: 1; }

/* ========== Buttons ========== */
.btn {
  padding: 12px 0;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  border: none;
}
.btn-primary { background: #07c160; color: #fff; }
.btn-secondary { background: #2a2a2a; color: #fff; border: 1px solid #3a3a3a; }
.btn:active { opacity: 0.8; }

/* ========== 分析说明卡片 ========== */
.help-inline {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #2a2a2a;
}
.help-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.help-icon { font-size: 32rpx; }
.help-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ccc;
}
.help-steps {
  padding: 4rpx 0;
  margin-top: 8rpx;
}
.help-step {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
}
.step-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  background: #1a2a3a;
  color: #60a5fa;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.step-text {
  font-size: 26rpx;
  color: #999;
  line-height: 40rpx;
  word-break: break-all;
}
.step-bold {
  color: #ddd;
  font-weight: 600;
}
.help-notice {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #2a2a2a;
}
.help-notice-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #f87171;
  margin-bottom: 10rpx;
}
.help-notice-text {
  display: block;
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  padding-left: 16rpx;
  margin-bottom: 6rpx;
}
