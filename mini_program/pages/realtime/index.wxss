/* pages/realtime/index.wxss */

/* ===== 页面基础 ===== */
page {
  height: 100%;
  width: 100%;
  background-color: #0d0d0d;
}

/* 未连接设备警告 */
.conn-warning {
  background: rgba(250,81,81,0.1);
  border: 1px solid rgba(250,81,81,0.3);
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  text-align: center;
}
.conn-warning-text {
  color: #fa5151;
  font-size: 24rpx;
}

.container {
  height: 100vh;
  background: #0d0d0d;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding: 0 !important;
  margin: 0 !important;
}

/* ========== 上半部分：数据区 ========== */
.data-section {
  flex-shrink: 0;
  width: 100%;
}

/* --- 标题行 --- */
.dt-header {
  display: flex;
  flex-direction: row;
  width: 100%;
  padding: 10rpx 4rpx;
  background: #141414;
  border-bottom: 2rpx solid #2a2a2a;
}

.th {
  text-align: center;
  font-size: 22rpx;
  color: #888;
  font-weight: bold;
  min-width: 0;
  overflow: hidden;
}
.th-time { color: #888; flex: 1.8; }
.th-rms   { color: #10b981; flex: 1.2; }
.th-act   { color: #07c160; flex: 1.0; }
.th-mdf   { color: #60a5fa; flex: 1.0; }
.th-fat   { color: #ff9800; flex: 1.0; }
.th-q     { color: #fff; flex: 1.0; }

/* --- 数据行（最新5帧）--- */
.dt-body {
  flex-shrink: 0;
  overflow-y: auto;
}

.dt-row {
  display: flex;
  flex-direction: row;
  width: 100%;
  padding: 10rpx 4rpx;
  border-bottom: 1rpx solid #1a1a1a;
  align-items: center;
  box-sizing: border-box;
}

.td {
  text-align: center;
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  color: #aaa;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.td-time { color: #bbb; flex: 1.8; }
.td-rms  { color: #10b981; font-weight: bold; flex: 1.2; }
.td-act  { color: #07c160; font-weight: bold; flex: 1.0; }
.td-mdf  { color: #60a5fa; font-weight: bold; flex: 1.0; }
.td-fat  { color: #ff9800; font-weight: bold; flex: 1.0; }
.td-q    { color: #fff; flex: 1.0; }

/* ========== 指标说明（统一help格式）========== */
.help-inline {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #2a2a2a;
}
.help-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.help-icon { font-size: 32rpx; }
.help-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ccc;
}
.help-steps {
  padding: 4rpx 0;
  margin-top: 8rpx;
}
.help-step {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
}
.step-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  background: #1a2a3a;
  color: #60a5fa;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.step-text {
  font-size: 26rpx;
  color: #999;
  line-height: 40rpx;
  word-break: break-all;
}
.step-bold { color: #e0e0e0; font-weight: 600; }

/* ========== 未连接遮罩 ========== */
.disconnected-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #0d0d0d;
  z-index: 10;
}
.dc-icon { font-size: 64px; }
.dc-title { font-size: 20px; font-weight: 600; color: #fff; }
.dc-desc { font-size: 14px; color: #888; }



.empty-placeholder {
  padding: 40rpx 16rpx;
  text-align: center;
}
.empty-placeholder .empty-desc {
  font-size: 24rpx;
  color: #555;
}

/* ========== 算法标识 ========== */
.algorithm-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #1a2a1a;
  border-bottom: 1rpx solid #2a4a2a;
}
.algo-label {
  font-size: 22rpx;
  color: #888;
}
.algo-value {
  font-size: 22rpx;
  color: #4ade80;
  font-weight: bold;
}
