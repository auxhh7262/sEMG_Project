/* pages/index/index.wxss - 设置页：WiFi配网内联 */

.container {
  min-height: 100vh;
  background: #0f0f0f;
  padding: 0 20rpx 60rpx;
  box-sizing: border-box;
}

/* 页面标题 */
.page-header {
  padding: 40rpx 0 30rpx;
  border-bottom: 1rpx solid #1e1e1e;
  margin-bottom: 30rpx;
}
.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

/* 区块 */
.section {
  background: #161616;
  border: 1rpx solid #222;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}
.section-about {
  opacity: 0.7;
}

/* 配网说明（独立区块） */
.section-help {
  opacity: 0.85;
}

/* 配网说明（内联版本，紧跟重置按钮） */
.help-inline {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #2a2a2a;
}
.help-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.help-icon {
  font-size: 32rpx;
}
.help-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ccc;
}
.help-steps {
  padding: 4rpx 0;
  margin-top: 8rpx;
}
.help-step {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
}
.step-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  background: #1a2a3a;
  color: #60a5fa;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.step-text {
  font-size: 26rpx;
  color: #999;
  line-height: 40rpx;
}
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  flex: 1;
}
.section-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.section-badge.idle { background: #2a2a2a; color: #888; }
.section-badge.scanning { background: #1a2a3a; color: #60a5fa; }
.section-badge.connected { background: #1a2a1a; color: #34d399; }
.section-badge.sending { background: #3a2a1a; color: #fbbf24; }
.section-badge.waiting { background: #1a2a1a; color: #34d399; }
.section-badge.success { background: #0a2a1a; color: #10b981; }
.section-badge.error { background: #2a0a0a; color: #f87171; }

/* 设备信息 */
.device-info {
  background: #0f0f0f;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}
.info-label {
  font-size: 26rpx;
  color: #888;
}
.info-value {
  font-size: 26rpx;
  color: #ccc;
  font-weight: 500;
}

/* 表单 */
.form-area {
  margin-top: 16rpx;
}
.form-field {
  margin-bottom: 28rpx;
}
.form-field:first-child .field-label {
  padding-top: 12rpx;
}
.field-label {
  display: block;
  font-size: 24rpx;
  color: #aaa;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  padding-top: 4rpx;
}
.field-input {
  width: 100%;
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #fff;
  box-sizing: border-box;
  transition: border-color 0.2s;
  height: 88rpx;
}
/* 带图标的输入框容器 */
.input-with-icon {
  display: flex;
  align-items: center;
  position: relative;
}
.field-input-icon {
  flex: 1;
  background: #1a1a1a;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 28rpx 60rpx 28rpx 24rpx;
  font-size: 30rpx;
  color: #fff;
  box-sizing: border-box;
  transition: border-color 0.2s;
  height: 88rpx;
}
.field-input-icon.input-locked {
  border-color: #333;
  color: #666;
  background: #0d0d0d;
}
.field-input-icon:focus {
  border-color: #10b981;
  outline: none;
}
.pwd-toggle {
  position: absolute;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 96rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.06);
}
.pwd-icon {
  font-size: 24rpx;
  color: #888;
  font-weight: 500;
  letter-spacing: 1rpx;
}
.field-input.input-locked {
  border-color: #333;
  color: #666;
  background: #0d0d0d;
}
.field-input.input-locked::placeholder {
  color: #444;
}
.field-input:focus {
  border-color: #10b981;
  outline: none;
}
.field-input::placeholder {
  color: #555;
}
.form-tip {
  display: block;
  font-size: 22rpx;
  color: #555;
  margin-bottom: 20rpx;
}

/* 按钮组（两按钮） */
.btn-group {
  display: flex;
  gap: 16rpx;
}

/* 按钮组（三按钮一排） - 统一高度80rpx，gap 12rpx */
.btn-group-three {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}
.btn-item {
  flex: 1;
  height: 80rpx;
  box-sizing: border-box;
  background: #1a2a3a;
  color: #60a5fa;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 10rpx;
  border: 0 solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-item:active { background: #1a3a4a; }
.btn-item.btn-scan { background: #1a2a3a; color: #60a5fa; }
.btn-item.btn-scan:active { background: #1a3a4a; }
.btn-item.btn-accent { background: #10b981; color: #fff; }
.btn-item.btn-accent:active { background: #059669; }
.btn-item.btn-reset { background: #2a1a1a; color: #f87171; }
.btn-item.btn-reset:active { background: #3a1a1a; }
.btn-item.btn-disabled { opacity: 0.4; }

/* ========== 选中指示线（顶部，固定在TabBar上方） ========== */

.btn-primary {
  flex: 1;
  height: 80rpx;
  background: #1a2a3a;
  color: #60a5fa;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 10rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary:active { background: #1a3a4a; }
.btn-accent {
  flex: 1;
  height: 80rpx;
  background: #10b981;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 10rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-accent:active { background: #059669; }
.btn-disabled {
  opacity: 0.4;
}

/* 结果横幅 */
.result-banner {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  margin-top: 16rpx;
}
.result-banner.success {
  background: rgba(16, 185, 129, 0.1);
  border: 1rpx solid rgba(16, 185, 129, 0.3);
}
.result-banner.error {
  background: rgba(248, 113, 113, 0.1);
  border: 1rpx solid rgba(248, 113, 113, 0.3);
}
.result-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.result-text {
  font-size: 26rpx;
  color: #fff;
  flex: 1;
}

/* IP 卡片 */
.ip-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #0a2a1a;
  border: 1rpx solid #1a3a2a;
  border-radius: 10rpx;
  padding: 20rpx 24rpx;
  margin-top: 16rpx;
  overflow: hidden;
}
.ip-left {
  display: flex;
  align-items: center;
  min-width: 0;
}
.ip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.ip-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.ip-label {
  font-size: 22rpx;
  color: #34d399;
  margin-bottom: 4rpx;
  white-space: nowrap;
}
.ip-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #10b981;
  word-break: break-all;
}

/* 重置说明 */
.reset-tip {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  margin-top: 16rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 10rpx;
}
.tip-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
}
.tip-text {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}



/* 手机网络信息卡 */
.phone-net-card {
  display: flex;
  align-items: center;
  background: rgba(96,165,250,0.08);
  border: 1px solid rgba(96,165,250,0.25);
  border-radius: 10px;
  padding: 10px 14px;
  margin-top: 8px;
}

.phone-net-card .ip-left {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
}

.phone-net-card .ip-icon {
  font-size: 20px;
  flex-shrink: 0;
}

.phone-net-card .ip-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.phone-net-card .ip-label {
  font-size: 13px;
  color: #60a5fa;
  font-weight: 500;
}

.phone-net-card .ip-value {
  font-size: 12px;
  color: #60a5fa;
  font-family: monospace;
  opacity: 0.8;
}
